// RUN: silc %s | FileCheck %s

// Test that `mod` flows through the pipeline and the final-phase module body
// survives as a `mir.func` with `isModule`, rather than being interpreted away.
// The const argument is still evaluated at compile time, but the resulting
// module function is preserved as hardware.

// The module's const phase is evaluated normally.
// CHECK-NOT: mir.func{{.*}}@identity.0a

// The module's last-phase function should survive with isModule, specialized
// with the constant argument inlined.
// CHECK: mir.func private @identity.{{[^ ]*}}() -> (result: !si.int) attributes {isModule}
// CHECK:   %c42_int = mir.constant #si.int<42>
// CHECK:   mir.return %c42_int

// The caller should call the module instead of being fully evaluated.
// CHECK: mir.func private @main.{{[^ ]*}}() -> (result: !si.int)
// CHECK:   mir.call @identity.
// CHECK:   mir.return
mod identity(const a: int) -> int { a }
fn main() -> int { identity(42) }
