// RUN: silc --ir-mir %s | FileCheck %s

// Test that `dyn` arguments compile through the full pipeline. A `dyn`
// argument shifts its phase forward, causing SplitPhases to place it in a
// later phase function.

// A dyn argument with a matching dyn return type compiles into a single
// phase-1 function.
// CHECK: mir.func private @dyn_identity.0b(%x: !si.int) -> (result: !si.int)
pub fn dyn_identity(dyn x: int) -> dyn int { x }

// A function with mixed const and dyn args. The dyn arg goes to a later
// phase function; the const arg is evaluated at compile time.
// CHECK-NOT: mir.func{{.*}}@mixed.0
// CHECK: mir.func private @mixed.2(%b: !si.int) -> ()
fn mixed(const a: int, dyn b: int) -> int { a }

// Calling a function with dyn args from main.
// CHECK: mir.evaluated_func {{.*}}@main.0b
pub fn main() -> int { mixed(42, 7) }
