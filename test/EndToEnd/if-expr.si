// RUN: silc %s | FileCheck %s

// Test if/else expressions evaluated at compile time. The const function
// `pick` returns one of two values based on a condition, and `main` calls
// it with a true condition (1 == 1) to select the first branch.

// CHECK: mir.evaluated_func {{.*}}@main.0{{.*}} [#si.int<42> : !si.int]

fn pick(const cond: int, const a: int, const b: int) -> int {
  if cond { a } else { b }
}
fn main() -> int { pick(1, 42, 7) }
