// RUN: silc %s | FileCheck %s
// RUN: silc --parse-only %s | silc --format=mlir --parse-only - | FileCheck --check-prefix=ROUNDTRIP %s

// Test that const arguments are evaluated at compile time through phased
// execution. The `add` function has a const argument `a` which gets split into
// a separate const-phase function. The compiler evaluates `add(42, 7)` at
// compile time, producing the constant result 49.

// CHECK: mir.evaluated_func {{.*}}@main.const0 [#mir.int<49> : !mir.int]

// ROUNDTRIP: hir.unified_func @add
// ROUNDTRIP: hir.unified_func @main
fn add(const a: int, b: int) -> int { a + b }
fn main() -> int { add(42, 7) }
