// RUN: silc --ir-mir %s | FileCheck %s

// Test that `const { ... }` blocks inside a function body correctly shift the
// phase of the enclosed expression. The `noargs` function returns a constant,
// and `main` wraps the call in a `const { ... }` block to force compile-time
// evaluation.

// CHECK: mir.evaluated_func {{.*}}@main{{.*}}[#si.int<42> : !si.int]
fn noargs() -> int { 42 }
fn main() -> int { const { noargs() } }
