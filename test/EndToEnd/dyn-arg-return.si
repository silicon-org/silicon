// RUN: silc --ir-hir %s | FileCheck %s --check-prefix=HIR
// RUN: silc --ir-mir %s | FileCheck %s --check-prefix=MIR

// Test that dyn returns compile through the pipeline. The return value is at
// phase 0 but the declared result phase is 1 (dyn), so the value flows through
// context.

// A dyn return type with a phase-0 value forwards through context.
// HIR-LABEL: hir.split_func @make_dyn(%x: 0) -> (result: 1)
// MIR: mir.func private @make_dyn.0(%x: !si.int) -> (ctx: !si.opaque)
pub fn make_dyn(x: int) -> dyn int { x }
