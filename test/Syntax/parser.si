// RUN: silc --test-parser %s | FileCheck %s

// CHECK-LABEL: name: "left_assoc"
fn left_assoc() {
  // CHECK: expr: BinaryExpr
  // CHECK:   lhs: BinaryExpr
  // CHECK:     lhs: BinaryExpr
  // CHECK:       lhs: NumLitExpr
  // CHECK:         value: 1
  // CHECK:       rhs: NumLitExpr
  // CHECK:         value: 2
  // CHECK:     rhs: NumLitExpr
  // CHECK:       value: 3
  // CHECK:   rhs: NumLitExpr
  // CHECK:     value: 4
  1 - 2 - 3 - 4;
}

// CHECK-LABEL: name: "precedence"
fn precedence() {
  // CHECK: expr: BinaryExpr
  // CHECK:   op: Add
  // CHECK:   lhs: BinaryExpr
  // CHECK:     op: Mul
  // CHECK:     lhs: NumLitExpr
  // CHECK:       value: 1
  // CHECK:     rhs: NumLitExpr
  // CHECK:       value: 2
  // CHECK:   rhs: BinaryExpr
  // CHECK:     op: Div
  // CHECK:     lhs: NumLitExpr
  // CHECK:       value: 3
  // CHECK:     rhs: NumLitExpr
  // CHECK:       value: 4
  1 * 2 + 3 / 4;
}

// CHECK-LABEL: name: "const_block"
fn const_block() {
  // CHECK: result: ConstExpr
  // CHECK:   value: BlockExpr
  // CHECK:     result: NumLitExpr
  // CHECK:       value: 42
  const { 42 }
}

// CHECK-LABEL: name: "dyn_block"
fn dyn_block() {
  // CHECK: result: DynExpr
  // CHECK:   value: BlockExpr
  // CHECK:     result: NumLitExpr
  // CHECK:       value: 42
  dyn { 42 }
}
