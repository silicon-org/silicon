// RUN: silc --parse-only %s | FileCheck %s

// Ensure we can call functions without result.
// CHECK-LABEL: hir.unified_func @unitResult1() -> (result: 0)
// CHECK: [[UNIT:%.+]] = hir.unit_type
// CHECK-NEXT: hir.unified_signature () -> ([[UNIT]])
fn unitResult1() {}
fn unitResult2() {
  unitResult1();
}
