// RUN: silc --parse-only %s | FileCheck %s

// CHECK-LABEL: hir.unified_func private @empty
// CHECK-SAME: () -> (result: 0)
// CHECK-NEXT: [[UNIT_TYPE:%.+]] = hir.unit_type
// CHECK-NEXT: hir.unified_signature () -> ([[UNIT_TYPE]])
fn empty() {}

// CHECK-LABEL: hir.unified_func private @simple
// CHECK-SAME: (%a: 0) -> (result: 0)
// CHECK-NEXT: [[A_TYPE:%.+]] = hir.int_type
// CHECK-NEXT: [[RET_TYPE:%.+]] = hir.int_type
// CHECK-NEXT: hir.unified_signature ([[A_TYPE]]) -> ([[RET_TYPE]])
fn simple(a: int) -> int { 0 }

// CHECK-LABEL: hir.unified_func private @dependent_types
// CHECK-SAME: (%a: 0, %b: -1, %c: 0) -> (result: 0)
// CHECK-NEXT: [[A_TYPE:%.+]] = hir.int_type
// CHECK-NEXT: [[B_TYPE:%.+]] = hir.int_type
// CHECK-NEXT: [[C_TYPE:%.+]] = hir.uint_type %b
// CHECK-NEXT: [[UNIT_TYPE:%.+]] = hir.unit_type
// CHECK-NEXT: hir.unified_signature ([[A_TYPE]], [[B_TYPE]], [[C_TYPE]]) -> ([[UNIT_TYPE]])
fn dependent_types(a: int, const b: int, c: uint<b>) {}

// CHECK-LABEL: hir.unified_func private @uint_literal_width
// CHECK-SAME: (%a: 0) -> (result: 0)
// CHECK-NEXT: [[WIDTH:%.+]] = hir.constant_int 42
// CHECK-NEXT: [[A_TYPE:%.+]] = hir.uint_type [[WIDTH]]
// CHECK-NEXT: [[UNIT_TYPE:%.+]] = hir.unit_type
// CHECK-NEXT: hir.unified_signature ([[A_TYPE]]) -> ([[UNIT_TYPE]])
fn uint_literal_width(a: uint<42>) {}

// CHECK-LABEL: hir.unified_func private @dyn_arg
// CHECK-SAME: (%x: 1) -> (result: 0)
fn dyn_arg(dyn x: int) -> int { x }

// CHECK-LABEL: hir.unified_func private @dyn_return
// CHECK-SAME: (%x: 0) -> (result: 1)
fn dyn_return(x: int) -> dyn int { x }

// CHECK-LABEL: hir.unified_func private @const_dyn_cancel
// CHECK-SAME: (%x: 0) -> (result: 0)
fn const_dyn_cancel(const dyn x: int) -> const dyn int { x }

// CHECK-LABEL: hir.unified_func private @dyn_dyn_arg
// CHECK-SAME: (%x: 2) -> (result: 0)
fn dyn_dyn_arg(dyn dyn x: int) -> int { x }

// CHECK-LABEL: hir.unified_func private @mixed_args
// CHECK-SAME: (%a: -1, %b: 1) -> (result: 0)
fn mixed_args(const a: int, dyn b: int) -> int { a }

// CHECK: hir.unified_func private @private_func() -> (result: 0)
fn private_func() {}

// CHECK: hir.unified_func @public_func() -> (result: 0)
pub fn public_func() -> int { 42 }

// CHECK-LABEL: hir.unified_func private @const_fn
// CHECK-SAME: (%a: -1, %b: -1) -> (result: -1)
const fn const_fn(a: int, b: int) -> int { a }

// CHECK-LABEL: hir.unified_func private @dyn_fn
// CHECK-SAME: (%a: 1) -> (result: 1)
dyn fn dyn_fn(a: int) -> int { a }

// CHECK-LABEL: hir.unified_func private @const_const_fn
// CHECK-SAME: (%x: -2) -> (result: -2)
const const fn const_const_fn(x: int) -> int { x }

// CHECK-LABEL: hir.unified_func private @const_dyn_cancel_fn
// CHECK-SAME: (%x: 0) -> (result: 0)
const dyn fn const_dyn_cancel_fn(x: int) -> int { x }

// CHECK-LABEL: hir.unified_func private @const_fn_with_arg_phases
// CHECK-SAME: (%a: -2, %b: 0) -> (result: -1)
const fn const_fn_with_arg_phases(const a: int, dyn b: int) -> int { a }

// CHECK-LABEL: hir.unified_func private @const_fn_dyn_return
// CHECK-SAME: (%x: -1) -> (result: 0)
const fn const_fn_dyn_return(x: int) -> dyn int { x }

// CHECK-LABEL: hir.unified_func @pub_const_fn
// CHECK-SAME: (%x: -1) -> (result: -1)
pub const fn pub_const_fn(x: int) -> int { x }
