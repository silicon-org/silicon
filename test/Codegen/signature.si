// RUN: silc --parse-only %s | FileCheck %s

// CHECK-LABEL: hir.unified_func @empty
// CHECK-SAME: [] -> [0]
// CHECK-NEXT: [[UNIT_TYPE:%.+]] = hir.unit_type
// CHECK-NEXT: hir.unified_signature () -> ([[UNIT_TYPE]])
fn empty() {}

// CHECK-LABEL: hir.unified_func @simple
// CHECK-SAME: [0] -> [0]
// CHECK-NEXT: [[INT_TYPE:%.+]] = hir.int_type
// CHECK-NEXT: [[A:%.+]] = hir.unified_arg "a", [[INT_TYPE]]
// CHECK-NEXT: [[INT_TYPE:%.+]] = hir.int_type
// CHECK-NEXT: hir.unified_signature ([[A]]) -> ([[INT_TYPE]])
fn simple(a: int) -> int { 0 }

// CHECK-LABEL: hir.unified_func @dependent_types
// CHECK-SAME: [0, 1, 0] -> [0]
// CHECK-NEXT: [[INT_TYPE:%.+]] = hir.int_type
// CHECK-NEXT: [[A:%.+]] = hir.unified_arg "a", [[INT_TYPE]]
// CHECK-NEXT: [[INT_TYPE:%.+]] = hir.int_type
// CHECK-NEXT: [[B:%.+]] = hir.unified_arg "b", [[INT_TYPE]]
// CHECK-NEXT: [[UINT_TYPE:%.+]] = hir.uint_type [[B]]
// CHECK-NEXT: [[C:%.+]] = hir.unified_arg "c", [[UINT_TYPE]]
// CHECK-NEXT: [[UNIT_TYPE:%.+]] = hir.unit_type
// CHECK-NEXT: hir.unified_signature ([[A]], [[B]], [[C]]) -> ([[UNIT_TYPE]])
fn dependent_types(a: int, const b: int, c: uint<b>) {}
